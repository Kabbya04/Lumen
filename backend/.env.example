# Copy to .env and adjust. Never commit .env.

# development | staging | production
APP_ENV=development

# Optional: shown in GET /health and GET /version
APP_VERSION=0.1.0

# Comma-separated browser origins for CORS (empty = no CORS middleware)
# Example for local Vite: http://localhost:5173
CORS_ORIGINS=

# Local Docker Compose Postgres (override with Supabase pooler/direct URL in cloud)
# Used by future phases; safe to set now for tooling consistency
DATABASE_URL=postgresql://lumen:lumen@db:5432/lumen
